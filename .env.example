# Model provider (triage agent)
OPENAI_API_KEY=

# GitHub App — READ-ONLY permissions: Pull requests, Contents, Metadata.
# The app must have NO write permissions; the read-only guardrail is enforced
# at the infrastructure layer, not by prompting.
GITHUB_APP_ID=
# PEM private key. Multi-line: escape newlines as \n or use a base64-encoded value.
GITHUB_PRIVATE_KEY=
# Webhook secret set on the GitHub App — signature verification is never skipped.
GITHUB_WEBHOOK_SECRET=
# Installation ID for the repo the app is installed on (e.g. CreatorSignal)
GITHUB_INSTALLATION_ID=
# Optional: personal access token fallback for local development against
# public repos when the App credentials above are not configured.
GITHUB_TOKEN=

# Slack (demo workspace)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Channel the triage cards post to (#factory)
SLACK_CHANNEL_ID=
